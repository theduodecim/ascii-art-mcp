{
  "name": "ascii-art-mcp",
  "version": "0.1.1",
  "mcpName": "io.github.theduodecim/ascii-art",
  "description": "MCP server that exposes ASCII and Unicode art tools",
  "type": "module",
  "main": "dist/server.js",

  "bin": {
    "ascii-art-mcp": "./dist/server.js"
  },

  "files": [
