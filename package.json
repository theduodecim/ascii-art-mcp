  },

  "homepage": "https://github.com/theduodecim/ascii-art-mcp",

  "license": "MIT",

  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.1",
    "zod": "^3.23.8"
  },

  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
